{
  "golden": {
    "phi": 1.6180339887,

    "axis": {
      "E": [1, 1.618, 2.618],
      "D": [1, 1.618, 2.618]
    },

    "matrix": {
      "size": "9x9",
      "blocks": "3x3",
      "ratio": [1, 1.618, 2.618]
    },

    "stability": {
      "formula": "(E + D) / phi",
      "threshold": 0.618
    },

    "lage": {
      "formula": "(X + Y + Z) / phi^2",
      "threshold": 0.382
    }
  },

  "bind": {
    "scale": "tmp.po.raer.tmp",
    "operator": "operator.tmp",
    "color": "ai.farb.map.tmp",
    "respo": "RESPO_ARG_SCAN.tmp",
    "ort": "ORT.scan"
  }
}
