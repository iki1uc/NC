{
  "ort": {
    "name": "Nord-Ost-Scan",
    "lage": "Nord-Ost",
    "axis": "NE",
    "value": 3.2,
    "richtung": {
      "x": "+",
      "y": "+",
      "z": "offen"
    }
  },

  "home": {
    "name": "Zentrum",
    "lage": "Center",
    "axis": "C",
    "value": 1.618,
    "phi": 1.6180339887
  },

  "delta": {
    "value": 1.582,
    "formula": "ORT.value - HOME.value",
    "phi": 1.618,
    "phi2": 2.618
  },

  "stabil": {
    "value": 0.618,
    "formula": "delta / phi",
    "threshold": 0.618,
    "status": "gelb-gruen"
  },

  "farbe": {
    "rot":   { "axis": "E1", "wert": 1 },
    "gruen": { "axis": "E2", "wert": 2 },
    "gelb":  { "axis": "E3", "wert": 3 },
    "lage.farbe": "gelb-gruen"
  },

  "respo": {
    "name": "Nord-Ost-Scan",
    "lage": "gelb-gruen",
    "stabil": 0.618,
    "delta": 1.582,
    "axis": "NE",
    "center": "C"
  },

  "bind": {
    "scale": "tmp.po.raer.tmp",
    "operator": "operator.tmp",
    "color": "ai.farb.map.tmp",
    "respo": "RESPO_ARG_SCAN.tmp",
    "ort": "ORT.scan"
  }
}
